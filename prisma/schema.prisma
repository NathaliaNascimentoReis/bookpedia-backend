generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Livro {
    id                  Int    @id @default(autoincrement())
    tituloDoLivro       String
    tituloDoLivroEn     String
    autor               String
    descricao           String
    descricaoEn         String
    contextoHistorico   String
    contextoHistoricoEn String
    anoDeLancamento     Int
    resumo              String
    resumoEn            String
    analise             String
    analiseEn           String
    capaURL             String

    @@map("livro")
}

model Enredos {
    id           Int    @id @default(autoincrement())
    introducao   String
    introducaoEn String
    conflito     String
    conflitoEn   String
    climax       String
    climaxEn     String
    desfecho     String
    desfechoEn   String
    idDoLivro    Int?

    @@map("enredos")
}

model MovimentosLiterarios {
    id                  Int    @id @default(autoincrement())
    nome                String
    contextoHistorico   String
    contextoHistoricoEn String
    caracteristicas     String
    caracteristicasEn   String
    periodo             String
    fase                String
    influencia          String
    idDoLivro           Int?

    @@map("movimentosLiterarios")
}

model Personagens {
    id          Int    @id @default(autoincrement())
    nome        String
    idade       Int
    descricao   String
    descricaoEn String
    historia    String
    historiaEn  String
    idDoLivro   Int?

    @@map("personagens")
}

model Videos {
    id          Int    @id @default(autoincrement())
    titulo      String
    tituloEn    String
    descricao   String
    descricaoEn String
    url         String
    idDoLivro   Int?

    @@map("videos")
}

model Curiosidades {
    id                  Int    @id @default(autoincrement())
    tituloCuriosidade   String
    tituloCuriosidadeEn String
    curiosidade         String
    curiosidadeEn       String
    idDoLivro           Int?

    @@map("curiosidades")
}

model Questoes {
    id             Int    @id @default(autoincrement())
    enunciado      String
    enunciadoEn    String
    vestibular     String
    anoVestibular  Int
    idAlternativas Int?
    idDoLivro      Int?

    @@map("questoes")
}

model Alternativas {
    id              Int    @id @default(autoincrement())
    alternativaA    String
    alternativaAEn  String
    alternatvaB     String
    alternativaBEn  String
    alternativaC    String
    alternativaCEn  String
    alternativaD    String
    alternativaDEn  String
    respostaCorreta String
    justificativa   String
    justificativaEn String

    @@map("alternativas")
}

model Vocabulario {
    id            Int    @id @default(autoincrement())
    palavra       String
    palavraEn     String
    significado   String
    significadoEn String
    idDoLivro     Int?

    @@map("vocabulario")
}

model Autores {
    id                  Int    @id @default(autoincrement())
    nome                String
    descricao           String
    descricaoEn         String
    contextoHistorico   String
    contextoHistoricoEn String
    anoNascimento       Int
    anoFalecimento      Int
    biografia           String
    biografiaEn         String
    movimentosLiterario String
    fotoURL             String
    idDoLivro           Int?

    @@map("autores")
}

model Cenarios {
    id                Int    @id @default(autoincrement())
    nome              String
    caracteristicas   String
    caracteristicasEn String
    descricao         String
    descricaoEn       String
    fotoURL           String
    idDoLivro         Int?

    @@map("cenarios")
}

model Membros {
    id              Int    @id @default(autoincrement())
    nome            String
    idade           Int
    curso           String
    cursoEn         String
    descricao       String
    descricaoEn     String
    cargo           String
    avaliacaoDaObra Int
    diasDeLeitura   Int
    opiniao         String
    idDoProjeto     Int?

    @@map("membros")
}

model Projetos {
    id                       Int    @id @default(autoincrement())
    nome                     String
    introducao               String
    introducaoEn             String
    objetivoProjeto          String
    objetivoProjetoEn        String
    sobreAEquipe             String
    sobreAEquipeEn           String
    desenvolvimentoTecnico   String
    desenvolvimentoTecnicoEn String
    tecnologias              String
    integracaoAPI            String
    integracaoAPIEn          String

    @@map("projetos")
}

model DicasDeVestibular {
    id       Int    @id @default(autoincrement())
    titulo   String
    tituloEn String
    dica     String
    dicaEn   String

    @@map("dicasDeVestibular")
}
