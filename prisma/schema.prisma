generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Livro {
    id                  Int    @id @default(autoincrement())
    tituloDoLivro       String
    tituloDoLivroEn     String
    descricao           String
    descricaoEn         String
    contextoHistorico   String
    contextoHistoricoEn String
    anoDeLancamento     Int
    resumo              String
    resumoEn            String
    analise             String
    analiseEn           String
    capaURL             String

    autores            Autores[]
    enredos            Enredos[]
    cenarios           Cenarios[]
    personagens        Personagens[]
    movimentoLiterario MovimentosLiterarios[]
    vocabularios       Vocabulario[]
    videos             Videos[]
    curiosidades       Curiosidades[]
    questoes           Questoes[]

    @@map("livro")
}

model Autores {
    id                  Int    @id @default(autoincrement())
    nome                String
    descricao           String
    descricaoEn         String
    contextoHistorico   String
    contextoHistoricoEn String
    anoNascimento       Int
    anoFalecimento      Int?
    biografia           String
    biografiaEn         String
    fotoURL             String

    livros Livro[]

    @@map("autores")
}

model Personagens {
    id          Int    @id @default(autoincrement())
    nome        String
    idade       Int?
    descricao   String
    descricaoEn String
    historia    String
    historiaEn  String

    idDoLivro Int
    livro     Livro @relation(fields: [idDoLivro], references: [id], onDelete: Cascade)

    @@map("personagens")
}

model Enredos {
    id           Int    @id @default(autoincrement())
    introducao   String
    introducaoEn String
    conflito     String
    conflitoEn   String
    climax       String
    climaxEn     String
    desfecho     String
    desfechoEn   String

    idDoLivro Int
    livro     Livro @relation(fields: [idDoLivro], references: [id], onDelete: Cascade)

    @@map("enredos")
}

model Cenarios {
    id                Int    @id @default(autoincrement())
    nome              String
    nomeEn            String
    caracteristicas   String
    caracteristicasEn String
    descricao         String
    descricaoEn       String
    fotoURL           String

    idDoLivro Int
    livro     Livro @relation(fields: [idDoLivro], references: [id], onDelete: Cascade)

    @@map("cenarios")
}

model Vocabulario {
    id            Int    @id @default(autoincrement())
    palavra       String
    palavraEn     String
    significado   String
    significadoEn String

    livros Livro[]

    @@map("vocabulario")
}

model MovimentosLiterarios {
    id                  Int    @id @default(autoincrement())
    nome                String
    contextoHistorico   String
    contextoHistoricoEn String
    caracteristicas     String
    caracteristicasEn   String
    periodo             String
    fase                String
    influencia          String

    livros Livro[]

    @@map("movimentosLiterarios")
}

model Videos {
    id          Int    @id @default(autoincrement())
    titulo      String
    tituloEn    String
    descricao   String
    descricaoEn String
    url         String

    idDoLivro Int
    livro     Livro @relation(fields: [idDoLivro], references: [id], onDelete: Cascade)

    @@map("videos")
}

model Curiosidades {
    id                  Int    @id @default(autoincrement())
    tituloCuriosidade   String
    tituloCuriosidadeEn String
    curiosidade         String
    curiosidadeEn       String

    idDoLivro Int
    livro     Livro @relation(fields: [idDoLivro], references: [id], onDelete: Cascade)

    @@map("curiosidades")
}

model Questoes {
    id            Int    @id @default(autoincrement())
    enunciado     String
    enunciadoEn   String
    vestibular    String
    anoVestibular Int

    alternativas Alternativas?

    idDoLivro Int
    livro     Livro @relation(fields: [idDoLivro], references: [id], onDelete: Cascade)

    @@map("questoes")
}

model Alternativas {
    id              Int    @id @default(autoincrement())
    alternativaA    String
    alternativaAEn  String
    alternativaB    String
    alternativaBEn  String
    alternativaC    String
    alternativaCEn  String
    alternativaD    String
    alternativaDEn  String
    respostaCorreta String
    justificativa   String
    justificativaEn String

    idQuestao Int      @unique
    questoes  Questoes @relation(fields: [idQuestao], references: [id], onDelete: Cascade)

    @@map("alternativas")
}

model Membros {
    id              Int    @id @default(autoincrement())
    nome            String
    idade           Int
    curso           String
    cursoEn         String
    descricao       String
    descricaoEn     String
    cargo           String
    avaliacaoDaObra Int
    diasDeLeitura   Int
    opiniao         String

    idDoProjeto Int
    projetos    Projetos @relation(fields: [idDoProjeto], references: [id], onDelete: Cascade)

    @@map("membros")
}

model Projetos {
    id                       Int    @id @default(autoincrement())
    nome                     String
    introducao               String
    introducaoEn             String
    objetivoProjeto          String
    objetivoProjetoEn        String
    sobreAEquipe             String
    sobreAEquipeEn           String
    desenvolvimentoTecnico   String
    desenvolvimentoTecnicoEn String
    tecnologias              String
    integracaoAPI            String
    integracaoAPIEn          String

    membros Membros[]

    @@map("projetos")
}

model DicasDeVestibular {
    id       Int    @id @default(autoincrement())
    titulo   String
    tituloEn String
    dica     String
    dicaEn   String

    @@map("dicasDeVestibular")
}
